generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  TRIAL
  NEW_SIGN_UP
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id                  String          @id @default(cuid())
  image               String?
  name                String?
  country             String?
  studentSince        DateTime?
  weeklySchedule      String?
  parentName          String?
  parentEmail         String?
  parentPhone         String?
  courseName          String?
  courseStage         String?
  teacherId           String?
  teacherName         String?
  groupClass          Boolean?        @default(false)
  groupSchedule       String?
  groupClassSchedule  String?
  groupTeacher        String?
  groupSubject        String?
  subject             String?
  teacherChanged      Boolean?        @default(false)
  previousTeacherName String?
  teacherChangeReason String?
  status              StudentStatus?  @default(ACTIVE)
  teacher             Teacher?        @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  courses             StudentCourse[]
  teacherChanges      TeacherChange[]
  classReports        ClassReport[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([teacherId])
}

model StudentCourse {
  id                String   @id @default(cuid())
  studentId         String
  courseInformation String?
  courseStage       String?
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([studentId])
}

model TeacherChange {
  id                  String   @id @default(cuid())
  studentId           String
  previousTeacherName String?
  newTeacherName      String?
  changingReason      String?
  changedAt           DateTime @default(now())
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([studentId])
}

model Teacher {
  id                            String           @id @default(uuid())
  name                          String?
  imageUrl                      String?
  joiningDate                   DateTime?
  status                        TeacherStatus?   @default(ACTIVE)
  strongArea                    String?
  totalStudentsAssignedLifetime Int?             @default(0)
  currentActiveStudents         Int?             @default(0)
  studentLeftLifetime           Int?             @default(0)
  students                      Student[]
  classReports                  ClassReport[]
  studentLeftLogs               StudentLeftLog[]
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt
}

model ClassReport {
  id                       String    @id @default(cuid())
  month                    String?
  studentId                String?
  teacherId                String?
  studentName              String?
  teacherName              String?

  studentWebcamOn          Boolean?
  studentWebcamPosition    String?
  studentWebcamQuality     String?
  studentNoiseFree         String?
  studentDevice            String?
  studentDressup           String?
  attentionFocus           String?
  activityInClass          String?
  lessonUnderstanding      String?
  languageUnderstanding    String?
  teacherNote              String?

  teacherWebcamOn          Boolean?
  teacherWebcamPosition    String?
  teacherWebcamQuality     String?
  recommendedHeadphone     String?
  teacherNoiseFree         String?
  tutorDevice              String?
  tutorDressup             String?
  teachingFocus            String?
  teachingTone             String?
  toolsAndContentUse       String?
  studentInteraction       String?
  correctionQuality        String?
  adminNote                String?

  student                  Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  teacher                  Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([studentId])
  @@index([teacherId])
  @@index([month])
}

model StudentLeftLog {
  id            String   @id @default(uuid())
  teacherId     String
  studentName   String?
  leavingReason String?
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([teacherId])
}
